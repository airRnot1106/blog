---
import BaseLayout from './BaseLayout.astro';
import PublishDateText from '@/components/case/publish/atoms/PublishDateText.astro';
import UpdateDateText from '@/components/case/update/atoms/UpdateDateText.astro';

export type ArticleLayoutProps = {
  title: string;
  subTitle?: string | undefined;
  description?: string | undefined;
  publishedAt: Date | undefined;
  updatedAt?: Date | null | undefined;
};
type Props = ArticleLayoutProps;
const { title, subTitle, description, publishedAt, updatedAt } = Astro.props;
---

<BaseLayout>
  <header class="flex flex-col items-center ~px-2/8 ~pt-6/12">
    <h1 class="~text-3xl/6xl font-bold">{title}</h1>
    {subTitle && <p class="~text-xs/2xl ~mt-0/1 font-ich1Q">{subTitle}</p>}
    {description && <p class="~text-sm/base mt-4">{description}</p>}
    <div class="flex items-center ~gap-2/4 mt-2 ~mb-1/0 self-end">
      {
        publishedAt && (
          <PublishDateText
            date={publishedAt}
            size={16}
            class="text-rosePineDawn-iris ~text-xs/base"
          />
        )
      }
      {
        updatedAt && (
          <UpdateDateText
            date={updatedAt}
            size={16}
            class="text-rosePineDawn-iris ~text-xs/base"
          />
        )
      }
    </div>
  </header>
  <hr class="~mx-2/8" />
  <div
    class="prose lg:prose-xl max-w-none prose-headings:text-rosePineDawn-text prose-p:text-rosePineDawn-text prose-h1:before:content-['#'] prose-h2:before:content-['##'] prose-h3:before:content-['###'] prose-h4:before:content-['####'] prose-headings:before:mr-2 prose-headings:before:text-rosePineDawn-foam/80 hover:prose-headings:before:text-rosePineDawn-foam prose-headings:before:scale-90 prose-headings:before:inline-block ~px-6/96 ~py-4/6"
  >
    <slot />
  </div>
</BaseLayout>
