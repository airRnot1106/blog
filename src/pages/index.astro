---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="flex flex-col items-center ~px-2/8 ~py-4/8 space-y-2">
    <h1 class="~text-4xl/7xl font-bold font-ich1Q">airRnot.dev</h1>
    <p class="~text-base/3xl font-ich1Q">airRnot's blog</p>
  </div>
  <div class="~px-2/8 ~py-4/8 space-y-4">
    <div class="flex items-center space-x-2">
      <h2 class="~text-xl/3xl font-bold">最近の活動</h2>
      <p class="~text-xs/sm font-bold font-ich1Q">さいきんのかつどう</p>
    </div>
    <div>
      <div class="flex items-center space-x-2">
        <h3 class="~text-lg/2xl font-bold">技術記事</h3>
        <p class="~text-xs/sm font-bold font-ich1Q">わたしがかきました</p>
      </div>
    </div>
    <div>
      <div class="flex items-center space-x-2">
        <h3 class="~text-lg/2xl font-bold">TODO</h3>
        <p class="~text-xs/sm font-bold font-ich1Q">やりたいこと</p>
      </div>
    </div>
  </div>
</BaseLayout>
